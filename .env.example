# lunar-hal secrets — committed template.
#
# 1. Copy this file to .env:
#       cp .env.example .env
# 2. Fill in your real values.
# 3. .env is in .gitignore and will never be committed.
#
# If you run deploy/orchestrate.sh or deploy/run-podman.sh from the repo root
# with .env present, it is sourced automatically.

# --- ESA Gaia Archive ---
# Sign up at https://gea.esac.esa.int → Login.
# Anonymous access is allowed but limited in result-set size; authed users can
# pull much larger async jobs.
GAIA_USER=your_gaia_username
GAIA_PASS=your_gaia_password

# --- Run parameters (consumed by orchestrate.sh / podman compose) ---
TOTAL_STARS=30000000
CHUNK_SIZE=3000000
JOBS=3

# --- Sink: "s3" for MinIO/RustFS, "local" for ./data/ ---
SINK_KIND=s3

# --- Local MinIO (matches install/podman-compose.yml defaults) ---
# Used by `podman-compose -f install/podman-compose.yml up`.
# run-podman.sh overrides SPACES_ENDPOINT to 127.0.0.1:9000 when in host network.
SPACES_KEY=minioadmin
SPACES_SECRET=minioadmin
SPACES_BUCKET=lunar-hal-data
SPACES_REGION=us-east-1
SPACES_ENDPOINT=minio:9000

# --- DigitalOcean Spaces (cloud.digitalocean.com → Spaces → API) ---
# Generate under https://cloud.digitalocean.com → Spaces → API → "Spaces Keys".
# Uncomment and fill in to switch the sink to DigitalOcean in production.
# SPACES_KEY=your_spaces_access_key
# SPACES_SECRET=your_spaces_secret_key
# SPACES_REGION=sfo3
# SPACES_ENDPOINT=
WORKDIR=/work